# ---------------------------
# Backend (.NET/Node entries trimmed)
# Python environment / build artifacts
# ---------------------------

# Logs
logs/
*.log

# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
env/
.env/
venv/
venv.bak/
.venv/

# Build / packaging
build/
dist/
*.egg-info/
htmlcov/
.coverage
coverage.xml
.pytest_cache/
.mypy_cache/

# Environment/local config files (do not commit secrets)
.env
.env.local
.env.*

# Editor and IDE files
.vscode/
!.vscode/extensions.json
.idea/
/.idea
.DS_Store

# PDF templates uploads (user-provided)
# Keep .gitkeep but ignore actual uploaded PDF files
app/pdf_templates/*.pdf

# Misc
node_modules/
dist-ssr/
*.local
